{
  "name": "talking-cli",
  "version": "0.1.0",
  "description": "A linter that audits agent skills: is your CLI mute?",
  "type": "module",
  "bin": {
    "talking-cli": "dist/cli.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "benchmark:build": "tsc -p benchmark/tsconfig.json",
    "benchmark": "npm run benchmark:build && node benchmark/dist/cli.js",
    "benchmark:smoke": "npm run benchmark:build && node benchmark/dist/cli.js --provider stub --limit 3 --output-dir benchmark/results/smoke",
    "benchmark:diff": "npx tsx benchmark/scripts/generate-server-diff.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/"
  },
  "keywords": [
    "cli",
    "agent",
    "skill",
    "mcp",
    "lint"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DrDexter6000/talking-cli.git"
  },
  "bugs": {
    "url": "https://github.com/DrDexter6000/talking-cli/issues"
  },
  "homepage": "https://github.com/DrDexter6000/talking-cli#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^22.14.0",
    "glob": "^13.0.6",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
